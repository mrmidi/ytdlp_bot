# Telegram Bot Token (obtained from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Super Admin Telegram User ID (e.g. 1150695)
SUPER_ADMIN_ID=1150695

# SQLite Database connection string (using async aiosqlite driver)
DB_URL=sqlite+aiosqlite:///data/bot.db

# Path to the temporary directory for downloading videos
TMP_DIR=./tmp

# Optional: Local Telegram Bot API Server configurations (for 2GB uploads)
# If using docker-compose, this redirects requests from the bot container to the api container.
# Leave empty to use Telegram's public cloud endpoint.
TELEGRAM_API_SERVER_URL=http://telegram-bot-api:8081

# Credentials obtained from https://my.telegram.org to run the local API server
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
