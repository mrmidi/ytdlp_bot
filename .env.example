# Telegram Bot Token (obtained from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Super Admin Telegram User ID (e.g. 1150695)
SUPER_ADMIN_ID=1150695

# SQLite Database connection string (using async aiosqlite driver)
DB_URL=sqlite+aiosqlite:///data/bot.db

# Path to the temporary directory for downloading videos
TMP_DIR=./tmp
